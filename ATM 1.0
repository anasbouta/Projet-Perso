import random
import time
import json
import os

DATA_FILE = "users.json"

def charger_donnees():
    if not os.path.exists(DATA_FILE):
        # Création d'un fichier par défaut si inexistant
        initial_data = {
            "1981": {"solde": 1000000, "nom": "Dupont", "prenom": "Jean", "email": "jean.dupont@email.com"}
        }
        sauvegarder_donnees(initial_data)
        return initial_data
    with open(DATA_FILE, "r", encoding="utf-8") as f:
        return json.load(f)

def sauvegarder_donnees(users):
    with open(DATA_FILE, "w", encoding="utf-8") as f:
        json.dump(users, f, indent=4, ensure_ascii=False)

def generer_pin(users):
    while True:
        pin = str(random.randint(1000, 9999))
        if pin not in users:
            return pin

def envoyer_message(email, sujet, message):
    with open("messages.txt", "a", encoding="utf-8") as f:
        f.write(f"Pour: {email}\nSujet: {sujet}\nMessage: {message}\n---\n")

def atm():
    users = charger_donnees()
    
    while True:
        pin = input("Entrez votre code PIN: ")
        if pin not in users:
            create = input("Ce code PIN n'existe pas. Créer un compte ? (o/n): ")
            if create.lower() == 'o':
                try:
                    nom = input("Nom : ")
                    prenom = input("Prénom : ")
                    email = input("Email : ")
                    solde = float(input("Solde initial : "))
                    if solde < 0:
                        print("Solde invalide.")
                        continue
                    new_pin = generer_pin(users)
                    users[new_pin] = {"solde": solde, "nom": nom, "prenom": prenom, "email": email}
                    sauvegarder_donnees(users)
                    print(f"Succès ! Votre code PIN est : {new_pin}")
                except ValueError:
                    print("Entrée invalide.")
                continue
            else:
                print("Accès refusé.")
                continue

        # Session utilisateur
        while True:
            # On récupère le solde à jour depuis le dictionnaire
            balance = users[pin]["solde"]
            print(f"\nBonjour {users[pin]['prenom']} {users[pin]['nom']} | Solde : ${balance}")
            print("1. Dépôt | 2. Retrait | 3. Modif Prénom | 4. Modif Nom | 5. Modif Email | 6. Quitter")
            
            choice = input("Votre choix : ")
            
            if choice == '1':
                try:
                    amount = float(input("Montant à déposer : "))
                    if amount > 0:
                        users[pin]["solde"] += amount
                        sauvegarder_donnees(users)
                        print("Dépôt réussi.")
                        envoyer_message(users[pin]['email'], "Dépôt", f"Nouveau solde: ${users[pin]['solde']}")
                    else: print("Montant invalide.")
                except ValueError: print("Entrée invalide.")

            elif choice == '2':
                try:
                    amount = float(input("Montant à retirer : "))
                    if 0 < amount <= users[pin]["solde"]:
                        users[pin]["solde"] -= amount
                        sauvegarder_donnees(users)
                        print("Retrait réussi.")
                        envoyer_message(users[pin]['email'], "Retrait", f"Nouveau solde: ${users[pin]['solde']}")
                    else: print("Fonds insuffisants.")
                except ValueError: print("Entrée invalide.")

            elif choice == '3':
                users[pin]['prenom'] = input("Nouveau prénom : ")
                sauvegarder_donnees(users)
                print("Modifié !")
            
            elif choice == '4':  # Modifier le nom
                new_nom = input("Entrez le nouveau nom : ")
                print("Modification du nom en cours, veuillez patienter 10 secondes...")
                time.sleep(10)
                users[pin]['nom'] = new_nom
                print("Nom modifié avec succès !")
                sauvegarder_donnees(users)
                envoyer_message(users[pin]['email'], "Nom modifié", f"Votre nom a été changé en {new_nom}.")
            elif choice == '5':  # Modifier l'email
                new_email = input("Entrez la nouvelle adresse email : ")
                users[pin]['email'] = new_email
                print("Email modifié avec succès !")
                sauvegarder_donnees(users)
                envoyer_message(new_email, "Email modifié", f"Votre adresse email a été changée en {new_email}.")

            elif choice == '6':
                print("Déconnexion...")
                break
            
            # (Ajoute les options 4 et 5 sur le même modèle que la 3)

        print("\n--- Session terminée ---")
        time.sleep(2)

if __name__ == "__main__":
    atm()
